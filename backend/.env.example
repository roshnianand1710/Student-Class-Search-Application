# Copy this file to .env and fill in your real values.

# Postgres connection string (Supabase pooler URL works).
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres

# Port the Express server listens on.
PORT=4000

# Groq API key for the LLM that parses search queries.
AI_API_KEY=
